PORT = 3000;
BD_Host = localhost;
DB_User = root;
DB_Password = password;
DB_Database = weatherApp;
WEATHER_API_KEY = your_api_key_here;

// for your actual application, replace 'your_api_key_here' with your real API key from OpenWeatherMap or any other weather service you are using.
// for your reference, that i push the .env file to the repository, but in a real-world scenario, you should add .env to your .gitignore file to prevent sensitive information from being exposed in version control.